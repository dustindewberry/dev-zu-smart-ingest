# =============================================================================
# Zubot Ingestion Service — example environment configuration
# Copy to `.env` and fill in real values for your deployment.
# Never commit `.env` — only `.env.example` belongs in version control.
# =============================================================================

# -----------------------------------------------------------------------------
# HTTP server
# -----------------------------------------------------------------------------
ZUBOT_HOST=0.0.0.0
ZUBOT_PORT=4243

# -----------------------------------------------------------------------------
# Database (PostgreSQL)
# -----------------------------------------------------------------------------
# asyncpg-compatible URL. For local docker compose: postgres://zubot:zubot@postgres:5432/zubot_ingestion
DATABASE_URL=postgresql+asyncpg://zubot:zubot@postgres:5432/zubot_ingestion

# -----------------------------------------------------------------------------
# Redis (Celery broker + rate limit backend)
# -----------------------------------------------------------------------------
# DB 2: Celery broker
# DB 3: Celery result backend
# DB 4: slowapi rate limit storage
REDIS_URL=redis://redis:6379
CELERY_BROKER_URL=redis://redis:6379/2
CELERY_RESULT_BACKEND=redis://redis:6379/3
RATE_LIMIT_STORAGE_URL=redis://redis:6379/4

# -----------------------------------------------------------------------------
# Ollama (vision + text inference)
# -----------------------------------------------------------------------------
OLLAMA_HOST=http://ollama:11434
OLLAMA_VISION_MODEL=qwen2.5vl:7b
OLLAMA_TEXT_MODEL=qwen2.5:7b
OLLAMA_REQUEST_TIMEOUT_SECONDS=120

# -----------------------------------------------------------------------------
# ChromaDB (metadata vector store)
# -----------------------------------------------------------------------------
CHROMADB_HOST=chromadb
CHROMADB_PORT=8002

# -----------------------------------------------------------------------------
# Elasticsearch (companion document full-text index)
# -----------------------------------------------------------------------------
ELASTICSEARCH_URL=http://elasticsearch:9200

# -----------------------------------------------------------------------------
# OpenTelemetry / Phoenix
# -----------------------------------------------------------------------------
OTEL_EXPORTER_OTLP_ENDPOINT=http://phoenix:4317
OTEL_SERVICE_NAME=zubot-ingestion
OTEL_TRACES_EXPORTER=otlp
OTEL_RESOURCE_ATTRIBUTES=service.name=zubot-ingestion,service.version=0.1.0

# -----------------------------------------------------------------------------
# Authentication
# -----------------------------------------------------------------------------
# Static API key for service-to-service calls
ZUBOT_INGESTION_API_KEY=replace-me-with-a-strong-random-secret

# Shared secret used to verify WOD-issued JWT bearer tokens
WOD_JWT_SECRET=replace-me-with-the-wod-jwt-signing-secret
WOD_JWT_ALGORITHM=HS256

# -----------------------------------------------------------------------------
# Rate limiting
# -----------------------------------------------------------------------------
RATE_LIMIT_DEFAULT=100/minute
RATE_LIMIT_EXTRACT=20/minute

# -----------------------------------------------------------------------------
# Logging
# -----------------------------------------------------------------------------
LOG_LEVEL=INFO
LOG_DIR=/var/log/zubot-ingestion
LOG_FORMAT=json
LOG_RETENTION_DAYS=7

# -----------------------------------------------------------------------------
# Pipeline tuning
# -----------------------------------------------------------------------------
MAX_COMPANION_PAGES=4
CONFIDENCE_AUTO_THRESHOLD=0.8
CONFIDENCE_REVIEW_THRESHOLD=0.5

# -----------------------------------------------------------------------------
# Test fixtures
# -----------------------------------------------------------------------------
# Absolute path to the directory containing real construction PDFs.
# Used by integration / accuracy tests; leave blank in production.
TEST_PDF_DIR=
